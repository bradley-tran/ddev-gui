{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "DDEV GUI",
  "outputfilename": "ddev-gui",
  "description": "A minimal Wails v2 desktop app to drive common ddev commands via a simple GUI.",
  "version": "2",
  "wailsjsdir": "frontend/wailsjs",
  "assetdir": "frontend/dist",
  "frontend:dir": "frontend",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "http://localhost:5173",
  "info": {
    "companyName": "",
    "productName": "DDEV GUI",
    "productVersion": "0.0.0.0",
    "copyright": "",
    "comments": "A desktop app for managing DDEV projects"
  }
}
